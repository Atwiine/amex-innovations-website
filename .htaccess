# Old static page names now redirect to their dynamic PHP equivalents.
RewriteEngine On
RewriteRule ^index\.html$ /index.php [R=301,L]
RewriteRule ^about\.html$ /about.php [R=301,L]
RewriteRule ^services\.html$ /services.php [R=301,L]
RewriteRule ^projects\.html$ /projects.php [R=301,L]
RewriteRule ^contact\.html$ /contact.php [R=301,L]

# Serve the dynamic sitemap at the conventional /sitemap.xml URL.
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# ── Force HTTPS + non-www ────────────────────────────────────────
# Enable this once SSL is active on Hostinger (hPanel > SSL) — left off here
# so local development over plain http still works.
# RewriteCond %{HTTPS} off [OR]
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://amexinnovations.com%{REQUEST_URI} [L,R=301]

# ── Compression ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Browser caching ───────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg     "access plus 1 year"
    ExpiresByType image/jpeg    "access plus 1 year"
    ExpiresByType image/png     "access plus 1 year"
    ExpiresByType image/webp    "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon  "access plus 1 year"
    ExpiresByType text/css      "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html     "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|css|js|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

ErrorDocument 404 /404.php
